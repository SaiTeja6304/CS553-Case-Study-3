    {
      "type": "barchart",
      "title": "Frontend API Response Time Histogram (last 24h)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "expr": "sum(increase(api_frontend_requesttime_seconds_bucket{le=\"60.0\"}[24h]))",
          "legendFormat": "0-60s",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum(increase(api_frontend_requesttime_seconds_bucket{le=\"120.0\"}[24h])) - sum(increase(api_frontend_requesttime_seconds_bucket{le=\"60.0\"}[24h]))",
          "legendFormat": "60-120s",
          "refId": "B",
          "instant": true
        },
        {
